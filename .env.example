# CalmSense environment variables (copy to .env; .env is git-ignored)

# API: allowed CORS origins for the dashboard (comma-separated)
CALMSENSE_CORS_ORIGINS=http://localhost:3000,https://urme-b.github.io

# Frontend: point the dashboard at a running API (optional; otherwise it runs
# the model in-browser via ONNX)
# REACT_APP_API_URL=http://localhost:8000
