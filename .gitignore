# =============================================================================
# CalmSense - Python/Data Science .gitignore
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# =============================================================================
# Data Science / ML Specific
# =============================================================================

# Raw data files (too large for git)
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

# Processed data
data/processed/*
!data/processed/.gitkeep

# Interim data
data/interim/*
!data/interim/.gitkeep

# External data
data/external/*
!data/external/.gitkeep

# Model files, except the small serving + in-browser models
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
*.onnx
!frontend/public/model.onnx
outputs/models/*
!outputs/models/.gitkeep
!outputs/models/stress_classifier.joblib

# =============================================================================
# IDE / Editor
# =============================================================================

# Local agent workspace
.claude/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =============================================================================
# OS Generated
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# Project Specific
# =============================================================================

# Logs
logs/*
!logs/.gitkeep
*.log

# Figures: keep generated result PNGs
outputs/figures/*
!outputs/figures/.gitkeep
!outputs/figures/*.png

# Demo (synthetic) outputs — never overwrite the committed real-WESAD results
results/demo/
outputs/figures/demo/
outputs/models/demo/

# Reports
outputs/reports/*
!outputs/reports/.gitkeep

# Temporary files
tmp/
temp/
*.tmp
*.temp

# API keys and secrets
.env
.env.*
!.env.example
secrets.yaml
credentials.json
*.pem
*.key

# Configuration overrides (local)
configs/local/
*.local.yaml

# Docker
.docker/

# Node.js (for frontend)
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.next/
frontend/.nuxt/
frontend/.cache/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Profiling
*.prof
*.lprof

# Reports and generated docs
*.docx
